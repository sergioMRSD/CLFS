def _normalize_value(value: object) -> Optional[str]:
    if pd.isna(value): return None
    text = str(value).strip()
    return text if text else None


def _normalize_header(text: object) -> str:
    if text is None: return ""
    return str(text).strip().lower()


def _column_matches(col_name: object, target: str) -> bool:
    col_norm = _normalize_header(col_name)
    target_norm = _normalize_header(target)
    return target_norm == col_norm or target_norm in col_norm


def _find_column_name(columns: list, target: str) -> Optional[str]:
    if not columns: return None
    target_norm = _normalize_header(target)
    exact = [c for c in columns if _normalize_header(c) == target_norm]
    if exact: return exact[0]
    partial = [c for c in columns if target_norm and target_norm in _normalize_header(c)]
    if not partial: return None
    return sorted(partial, key=lambda c: len(_normalize_header(c)))[0]


def _find_column_indices(columns: list, target: str) -> list[int]:
    return [i for i, col in enumerate(columns) if _column_matches(col, target)]


def _get_cell_value(df: pd.DataFrame, row_idx: int, target: str) -> Optional[object]:
    col_name = _find_column_name(list(df.columns), target)
    if not col_name: return None
    return df.at[row_idx, col_name]


def _get_column_index(df: pd.DataFrame, target: str) -> tuple[Optional[str], Optional[int]]:
    col_name = _find_column_name(list(df.columns), target)
    if not col_name: return None, None
    return col_name, df.columns.get_loc(col_name)


def _normalize_text(value: object) -> str:
    if value is None: return ""
    return str(value).strip().lower()


def _ensure_ssic_column(df: pd.DataFrame) -> tuple[pd.DataFrame, Optional[str]]:
    est_col = _find_column_name(list(df.columns), "Name of Establishment you were working last week?")
    if not est_col: return df, None
    ssic_col = _find_column_name(list(df.columns), "SSIC Code")
    if ssic_col: return df, ssic_col
    cols = list(df.columns)
    insert_at = cols.index(est_col) + 1
    cols.insert(insert_at, "SSIC Code")
    df = df.reindex(columns=cols)
    df = df.copy()
    return df, "SSIC Code"


def _gmi_range_to_group(gmi_range: str) -> Optional[int]:
    if not gmi_range: return None
    text = _normalize_text(gmi_range)
    if "any" in text: return None
    if ">" in text and "9000" in text: return 1
    if "7000" in text and "8999" in text: return 2
    if "3000" in text and ("6999" in text or "5999" in text): return 3
    if "2000" in text and "2999" in text: return 4
    if "below" in text: return 5
    if "above" in text and ("3000" in text or "2500" in text): return 3
    return None


def _build_ssoc_min_group_map(entries: list[dict]) -> dict[str, int]:
    mapping = {}
    for entry in entries:
        code = str(entry.get("ssoc", "")).strip()
        rng = str(entry.get("gmi_range", "")).strip()
        if not code: continue
        group = _gmi_range_to_group(rng)
        if group is None: continue
        current = mapping.get(code)
        mapping[code] = group if current is None else min(current, group)
    return mapping


SSOC_MIN_GROUP_BY_CODE = _build_ssoc_min_group_map(GMI_HQA_ENTRIES)


def _parse_gmi_value(gmi_value: Optional[object]) -> Optional[float]:
    if gmi_value is None or gmi_value == "": return None
    try: return float(gmi_value)
    except: return None


def _gmi_in_range(gmi_value: float, gmi_range: str) -> bool:
    if gmi_value is None or gmi_range is None: return False
    text = _normalize_text(gmi_range)
    if "any" in text: return True
    nums = [int(n) for n in re.findall(r"\d+", text)]
    if not nums: return False
    if "below" in text: return gmi_value <= nums[0]
    if "above" in text or text.startswith(">"): return gmi_value >= nums[0]
    if len(nums) >= 2: return nums[0] <= gmi_value <= nums[1]
    return False


def _hqa_matches_entry(hqa_value: Optional[str], entry_hqa: str) -> bool:
    hqa = _normalize_text(hqa_value)
    ent = _normalize_text(entry_hqa)
    if not hqa or not ent: return False
    if "degree" in ent or "master" in ent: return "degree" in hqa or "master" in hqa
    if "diploma and above" in ent: return "diploma" in hqa or "degree" in hqa or "master" in hqa
    if "secondary/ite/diploma" in ent: return "secondary" in hqa or "ite" in hqa or "diploma" in hqa
    if "secondary/ite" in ent: return "secondary" in hqa or "ite" in hqa
    if "diploma and below" in ent: return "degree" not in hqa and "master" not in hqa
    if "ite and below" in ent: return "ite" in hqa or "secondary" in hqa or "below" in hqa
    if "secondary and below" in ent: return "degree" not in hqa and "master" not in hqa and "diploma" not in hqa
    return ent in hqa


def _select_candidate_by_examples(top_5: list[dict], hqa_value: Optional[str], gmi_value: Optional[float]) -> Optional[str]:
    if not top_5 or gmi_value is None: return None
    for cand in top_5:
        code = str(cand.get("code", "")).strip()
        if not code: continue
        for entry in GMI_HQA_ENTRIES:
            if code != str(entry.get("ssoc", "")).strip(): continue
            if not _hqa_matches_entry(hqa_value, str(entry.get("hqa", ""))): continue
            if _gmi_in_range(gmi_value, str(entry.get("gmi_range", ""))): return code
    return None


def _required_group_from_band(hqa_value: Optional[str], gmi_value: Optional[float]) -> Optional[int]:
    if gmi_value is None: return None
    for band in GMI_GROUP_BANDS:
        if not _hqa_matches_entry(hqa_value, band.get("hqa", "")): continue
        if _gmi_in_range(gmi_value, band.get("gmi_range", "")): return band.get("group")
    return None


def _select_candidate_by_band(top_5: list[dict], required_group: Optional[int]) -> Optional[str]:
    if required_group is None or not top_5: return None
    for cand in top_5:
        code = str(cand.get("code", "")).strip()
        if not code: continue
        min_g = SSOC_MIN_GROUP_BY_CODE.get(code)
        if min_g is None or min_g >= required_group: return code
    return None


def _get_member_column_groups(columns: list[str]) -> list[dict[str, Optional[int]]]:
    fn_idx = _find_column_indices(columns, "Full Name")
    groups = []
    for idx, f_idx in enumerate(fn_idx):
        nxt = fn_idx[idx + 1] if idx + 1 < len(fn_idx) else len(columns)
        groups.append({"full_name_idx": f_idx})
    return groups


def extract_household_members(df: pd.DataFrame) -> list[list[HouseholdMember]]:
    columns = list(df.columns)
    groups = _get_member_column_groups(columns)
    households = []
    for _, row in df.iterrows():
        members = []
        for group in groups:
            name = _normalize_value(row.iloc[group["full_name_idx"]])
            if not name: continue
            member = HouseholdMember(full_name=name)
            for attr, col in COLUMN_MAPPING.items():
                if attr == "full_name": continue
                matched = _find_column_name(columns, col)
                if matched:
                    c_idx = columns.index(matched)
                    val = _normalize_value(row.iloc[c_idx])
                    if val:
                        if attr in ["age", "num_foreign_domestic_workers", "number_of_children", "retirement_age"]:
                            try: val = int(float(val))
                            except: pass
                        elif attr in ["gmi", "bonus_received_last_12_months", "usual_hours_of_work"]:
                            try: val = float(val)
                            except: pass
                        setattr(member, attr, val)
            members.append(member)
        households.append(members)
    return households


def _detect_separator(file_path: Path) -> str:
    try:
        if file_path.suffix.lower() == '.tsv': return '\t'
        with open(file_path, 'r', encoding='utf-8-sig') as f:
            for _ in range(5): f.readline()
            header = f.readline().strip()
            if header.count('\t') > header.count(','): return '\t'
            return ','
    except: return '\t'


def load_input_files(folder_path="Operating_Table"):
    input_files = {}
    if not os.path.exists(folder_path): return input_files
    for file in Path(folder_path).glob("*.xlsx"):
        try:
            df = pd.read_excel(file)
            input_files[file.name] = _clean_dataframe(df)
        except Exception as e: print(f"Error loading {file.name}: {e}")
    for file in list(Path(folder_path).glob("*.csv")) + list(Path(folder_path).glob("*.tsv")):
        try:
            sep = _detect_separator(file)
            df = pd.read_csv(file, sep=sep, header=0, skiprows=range(5), encoding="utf-8-sig")
            input_files[file.name] = _clean_dataframe(df)
        except Exception as e: print(f"Error loading {file.name}: {e}")
    return input_files


def _clean_dataframe(df: pd.DataFrame) -> pd.DataFrame:
    df = df.dropna(how="all")
    df.columns = [str(col).strip() for col in df.columns]
    res_col = _find_column_name(list(df.columns), "Response ID")
    if res_col: df = df[df[res_col].notna()]
    return df.reset_index(drop=True)


def _ensure_ssec_column(df: pd.DataFrame) -> pd.DataFrame:
    if _find_column_name(list(df.columns), "SSEC Code"): return df
    hqa_col = _find_column_name(list(df.columns), "Highest Academic Qualification")
    if not hqa_col: return df
    cols = list(df.columns)
    at = cols.index(hqa_col) + 1
    cols.insert(at, "SSEC Code")
    df = df.reindex(columns=cols)
    df["SSEC Code"] = df["SSEC Code"].astype("object")
    return df.copy()


def _ensure_ssoc_columns(df: pd.DataFrame) -> tuple[pd.DataFrame, list[dict]]:
    columns = list(df.columns)
    duty_indices = _find_column_indices(columns, "Main tasks / duties")
    title_indices = _find_column_indices(columns, "Job Title")
    if not duty_indices: return df, []
    groups = []
    for idx, d_idx in enumerate(duty_indices):
        nxt = duty_indices[idx + 1] if idx + 1 < len(duty_indices) else len(columns)
        titles = [i for i in title_indices if d_idx < i < nxt]
        t_idx = titles[0] if titles else ([i for i in title_indices if i < d_idx][-1] if title_indices else None)
        groups.append({"title_idx": t_idx, "duties_idx": d_idx, "ssoc_idx": None})
    off = 0
    new_cols = list(df.columns)
    ins = []
    for g in sorted(groups, key=lambda x: x["duties_idx"]):
        d_idx = g["duties_idx"] + off
        at = d_idx + 1
        if at < len(new_cols) and _column_matches(new_cols[at], "SSOC Code"):
            g["ssoc_idx"] = at
        else:
            ins.append((at, g))
            new_cols.insert(at, "SSOC Code")
            off += 1
        g["duties_idx"], g["title_idx"] = d_idx, (g["title_idx"] + off if g["title_idx"] is not None else None)
    if ins:
        df = df.reindex(columns=new_cols)
        for c in new_cols:
            if "SSOC Code" in str(c): df[c] = df[c].astype("object")
        off = 0
        for idx, g in ins:
            g["ssoc_idx"] = idx + off
            off += 1
    return df.copy(), groups


def _add_ft_pt_columns(df: pd.DataFrame) -> tuple[pd.DataFrame, list[tuple[int, int, str]]]:
    changes = []
    c_idx = 0
    while c_idx < len(df.columns):
        if _column_matches(df.columns[c_idx], "Usual hours of work"):
            at = c_idx + 1
            if not (at < len(df.columns) and _column_matches(df.columns[at], "FT/PT")):
                df.insert(at, "FT/PT", "", allow_duplicates=True)
            ft_idx = at
            for r_idx, val in df.iloc[:, c_idx].items():
                try:
                    h = float(val)
                    res = "FT" if h >= 35 else "PT"
                    df.iat[r_idx, ft_idx] = res
                    changes.append((r_idx, ft_idx, res))
                except: df.iat[r_idx, ft_idx] = ""
            c_idx = ft_idx + 1
        else: c_idx += 1
    return df.copy(), changes


def create_output_directory():
    p = Path("output")
    p.mkdir(exist_ok=True)
    return p


def _apply_dataset_highlights(ws, changes: dict, error_cells: set[tuple[int, int]]):
    orange = PatternFill(start_color="FFA500", end_color="FFA500", fill_type="solid")
    yellow = PatternFill(start_color="FFFF00", end_color="FFFF00", fill_type="solid")
    for (r, c), (_, val) in changes.items():
        cell = ws.cell(row=r + 2, column=c + 1)
        cell.fill, cell.value = orange, val
    for (r, c) in error_cells:
        ws.cell(row=r + 2, column=c + 1).fill = yellow


