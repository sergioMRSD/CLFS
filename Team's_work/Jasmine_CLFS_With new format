def create_validation_report(
    rule_errors: list[dict],
    source_filename: str,
    validated_df: Optional[pd.DataFrame] = None,
    changes: Optional[dict] = None,
    error_cells: Optional[set[tuple[int, int]]] = None,
) -> Optional[Path]:
    """
    Dynamically expands the validation report to handle rules with multiple variables.
    Format: file, row, response_id, member, rule, column, message, corrections... Remarks
    """
    if not rule_errors: return None

    output_dir = create_output_directory()
    filename = Path(source_filename).stem
    report_path = output_dir / f"{filename}_validation_report.xlsx"

    processed_data = []
    max_variables = 1

    for err in rule_errors:
        entry = {
            "file": err.get("file"),
            "row": err.get("row"),
            "response_id": err.get("response_id"),
            "member": err.get("member"),
            "rule": err.get("rule"),
        }

        # Handle multi-column logic by splitting on '&'
        raw_columns = str(err.get("column", ""))
        var_list = [v.strip() for v in raw_columns.split("&")]
        msg = err.get("message", "")
        
        if len(var_list) > max_variables:
            max_variables = len(var_list)

        # Distribute variables across dynamic headers
        for i, var_name in enumerate(var_list):
            suffix = "" if i == 0 else f"_{i+1}"
            entry[f"column{suffix}"] = var_name
            entry[f"message{suffix}"] = msg
            entry[f"corrections{suffix}"] = ""

        entry["_row_ref"] = err.get("row")
        processed_data.append(entry)

    details_df = pd.DataFrame(processed_data)

    # Define final column order
    base_headers = ["file", "row", "response_id", "member", "rule"]
    dynamic_headers = []
    for i in range(max_variables):
        sfx = "" if i == 0 else f"_{i+1}"
        dynamic_headers.extend([f"column{sfx}", f"message{sfx}", f"corrections{sfx}"])
    
    # Contextual Remarks
    remarks = []
    if validated_df is not None and not validated_df.empty:
        rem_col = _find_column_name(list(validated_df.columns), "Remarks")
        if rem_col:
            for r_num in details_df["_row_ref"]:
                try:
                    idx = int(r_num) - 1
                    val = validated_df.at[idx, rem_col] if 0 <= idx < len(validated_df) else ""
                    remarks.append("" if pd.isna(val) else str(val))
                except: remarks.append("")
        else: remarks = [""] * len(details_df)
    else: remarks = [""] * len(details_df)
    
    details_df["Remarks"] = remarks

    # Filter columns and create Summary
    final_order = [c for c in base_headers + dynamic_headers + ["Remarks"] if c in details_df.columns]
    details_df = details_df[final_order]

    summary_df = (
        details_df.groupby(["rule", "column", "message"], dropna=False)
        .size().reset_index(name="count").sort_values("count", ascending=False)
    )

    # Save and Format
    with pd.ExcelWriter(report_path, engine="openpyxl") as writer:
        summary_df.to_excel(writer, sheet_name="Summary", index=False)
        details_df.to_excel(writer, sheet_name="Details", index=False)
        if validated_df is not None:
            validated_df.to_excel(writer, sheet_name="Complete Dataset", index=False)

    wb = load_workbook(report_path)
    yellow = PatternFill(start_color="FFFF00", end_color="FFFF00", fill_type="solid")

    if "Details" in wb.sheetnames:
        ws = wb["Details"]
        # Highlight all correction columns
        for c_idx, c_name in enumerate(details_df.columns, 1):
            if "corrections" in str(c_name):
                for r in range(1, ws.max_row + 1):
                    ws.cell(row=r, column=c_idx).fill = yellow

    if "Complete Dataset" in wb.sheetnames and (changes or error_cells):
        _apply_dataset_highlights(wb["Complete Dataset"], changes or {}, error_cells or set())
    
    wb.save(report_path)
    print(f"\n✓ Validation report saved to: {report_path}")
    return report_path
